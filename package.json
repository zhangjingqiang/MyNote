{
  "name": "mynote",
  "version": "1.0.0",
  "description": "A simple note-taking app with Electron, Markdown support",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .",
    "dev:renderer": "vite --clearScreen false",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.1.4",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.2"
  },
  "build": {
    "appId": "com.mynote.app",
    "productName": "MyNote",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "target": "dmg",
      "hardenedRuntime": false,
      "icon": "icon.png"
    },
    "win": {
      "target": "nsis"
    }
  }
}
